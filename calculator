# FUNÇÕES
def somar(a, b):
    return a + b

def subtrair(a, b):
    return a - b

def multiplicar(a, b):
    return a * b

def dividir_int(a, b):
    return a // b

def dividir_float(a, b):
    return a / b

def potencia(a, b):
    return a ** b

def resto(a, b):
    return a % b

